# ============================================================================
# Example environment file — safe to commit to GitHub.
# Copy this to `.env` and fill in real values:   cp .env.example .env
# ============================================================================

# Run mode
TESTNET=true          # true = Binance Futures demo (paper). false = LIVE.
INTERVAL=15m
PORT=5000

# Binance Futures API (demo keys: https://testnet.binancefuture.com)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Supabase (Project Settings -> API). Use the service_role key for SUPABASE_KEY.
# Leave blank to run without a database.
SUPABASE_URL=
SUPABASE_KEY=
